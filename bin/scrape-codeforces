#!/usr/bin/env python
# pylint: disable=invalid-name

"""This script scrapes Polban Codeforces leaderboard and outputs a JSON array
containing the parsed data."""

import json
import sys
import time
from re import findall
import requests
from bs4 import BeautifulSoup


URL = "https://codeforces.com/ratings/organization/3732"
USER_AGENT = "cp-leaderboard (https://github.com/jtkencode/cp-leaderboard)"
MAX_RETRIES = 5


def fetch(url):
    """fetch retrieves the given URL with retries and exponential backoff.

    It retries on non-200 status codes and on request exceptions (timeouts,
    connection errors, etc.), logging each failed attempt to stderr. On
    success it returns the response. If every attempt fails, it returns the
    last response (so the caller's assertions surface the issue) or re-raises
    the last exception when no response was ever received."""
    last_resp = None
    last_exc = None

    for attempt in range(1, MAX_RETRIES + 1):
        try:
            resp = requests.get(
                url, headers={"User-Agent": USER_AGENT}, timeout=10
            )
            if resp.status_code == 200:
                return resp

            last_resp = resp
            last_exc = None
            print(
                f"WARNING: attempt {attempt}/{MAX_RETRIES} got status "
                f"{resp.status_code} from {url}",
                file=sys.stderr,
            )
            print(f"Response headers: {dict(resp.headers)}", file=sys.stderr)
            print(
                f"Response body (first 2000 chars):\n{resp.text[:2000]}",
                file=sys.stderr,
            )
        except requests.exceptions.RequestException as exc:
            last_resp = None
            last_exc = exc
            print(
                f"WARNING: attempt {attempt}/{MAX_RETRIES} raised "
                f"{type(exc).__name__}: {exc}",
                file=sys.stderr,
            )

        if attempt < MAX_RETRIES:
            backoff = 2 ** attempt
            print(f"Retrying in {backoff}s ...", file=sys.stderr)
            time.sleep(backoff)

    if last_resp is not None:
        return last_resp
    raise last_exc


def is_active(cell):
    """is_active takes a BeautifulSoup object containing a <td> cell from
    Codeforces leaderboard and returns whether the user is still active or
    not."""
    return cell.find("span", title="outdated") is None

def get_polban_rank(cell):
    """get_polban_rank takes a BeautifulSoup object containing a <td> cell from
    Codeforces leaderboard and returns the user's rank across Polban users."""
    if not is_active(cell):
        return None

    res = findall(r'\d+', cell.get_text().strip())
    assert len(res) == 2

    return int(res[0])

result = []

req = fetch(URL)

soup = BeautifulSoup(req.content, "html.parser")
leaderboard_rows = soup.select(".ratingsDatatable tr")

# At October 17, 2020, the rating page lists 6 members, so this should be the
# baseline. (+1 for the heading row)
if len(leaderboard_rows) < 6 + 1:
    print(
        f"DEBUG: too few rows ({len(leaderboard_rows)}). Final status: "
        f"{req.status_code}",
        file=sys.stderr,
    )
    print(
        f"Response body (first 2000 chars):\n{req.text[:2000]}",
        file=sys.stderr,
    )
assert len(leaderboard_rows) >= 6 + 1

# But, due to Codeforces not closing <tr> tags properly, we only need to parse
# the "second" row ...
row = leaderboard_rows[1]
columns = row.find_all("td")

# ... and assert for a minimum of 6 members x 4 columns = 24 columns.
assert len(columns) >= (4 * 6)
assert len(columns) % 4 == 0

for i in range(0, len(columns), 4):
    entry = {
        "active": is_active(columns[i]),
        "polban_rank": get_polban_rank(columns[i]),
        "username": columns[i + 1].get_text().strip(),
        "participations": int(columns[i + 2].get_text().strip()),
        "rating": int(columns[i + 3].get_text().strip())
    }

    result.append(entry)

# Make the result stable by sorting it based on username as it cannot be changed
result = sorted(result, key=lambda item: item["username"])

print(json.dumps(result, indent=4, sort_keys=True))
