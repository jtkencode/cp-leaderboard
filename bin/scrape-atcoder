#!/usr/bin/env python
# pylint: disable=invalid-name

"""This script scrapes Polban Atcoder leaderboard and outputs a JSON array
containing the parsed data."""

import json
import sys
import time
from re import findall
import requests
from bs4 import BeautifulSoup


URL = "https://atcoder.jp/ranking/all?f.Affiliation=Bandung+State+Polytechnic"
USER_AGENT = "cp-leaderboard (https://github.com/jtkencode/cp-leaderboard)"
MAX_RETRIES = 5


def fetch(url):
    """fetch retrieves the given URL with retries and exponential backoff.

    It retries on non-200 status codes and on request exceptions (timeouts,
    connection errors, etc.), logging each failed attempt to stderr. On
    success it returns the response. If every attempt fails, it returns the
    last response (so the caller's assertions surface the issue) or re-raises
    the last exception when no response was ever received."""
    last_resp = None
    last_exc = None

    for attempt in range(1, MAX_RETRIES + 1):
        try:
            resp = requests.get(
                url, headers={"User-Agent": USER_AGENT}, timeout=10
            )
            if resp.status_code == 200:
                return resp

            last_resp = resp
            last_exc = None
            print(
                f"WARNING: attempt {attempt}/{MAX_RETRIES} got status "
                f"{resp.status_code} from {url}",
                file=sys.stderr,
            )
            print(f"Response headers: {dict(resp.headers)}", file=sys.stderr)
            print(
                f"Response body (first 2000 chars):\n{resp.text[:2000]}",
                file=sys.stderr,
            )
        except requests.exceptions.RequestException as exc:
            last_resp = None
            last_exc = exc
            print(
                f"WARNING: attempt {attempt}/{MAX_RETRIES} raised "
                f"{type(exc).__name__}: {exc}",
                file=sys.stderr,
            )

        if attempt < MAX_RETRIES:
            backoff = 2 ** attempt
            print(f"Retrying in {backoff}s ...", file=sys.stderr)
            time.sleep(backoff)

    if last_resp is not None:
        return last_resp
    raise last_exc


def get_username(cell):
    """get_username takes a BeautifulSoup object containing a <td> cell from
    Atcoder leaderboard and outputs the parsed username from the <a> tag."""
    raw = cell.find("a", {"class": "username"}).get("href").strip()
    assert raw[:7] == "/users/"

    return raw[7:]

def get_polban_rank(cell):
    """get_polban_rank takes a BeautifulSoup object containing a <td> cell from
    Atcoder leaderboard and returns the user's rank across Polban users."""
    res =  findall(r'\d+', cell.get_text().strip())
    assert len(res) >= 1

    return int(res[0])

result = []

req = fetch(URL)

soup = BeautifulSoup(req.content, "html.parser")
leaderboard_rows = soup.select(".table-responsive tbody tr")
if len(leaderboard_rows) == 0:
    print(
        f"DEBUG: no rows found. Final status: {req.status_code}",
        file=sys.stderr,
    )
    print(
        f"Response body (first 2000 chars):\n{req.text[:2000]}",
        file=sys.stderr,
    )
assert len(leaderboard_rows) > 0

for row in leaderboard_rows:
    columns = row.find_all("td")
    assert len(columns) == 7

    entry = {
        "polban_rank": get_polban_rank(columns[0]),
        "username": get_username(columns[1]),
        "birth": int(columns[2].get_text().strip()),
        "rating": int(columns[3].get_text().strip()),
        "highest": int(columns[4].get_text().strip()),
        "match": int(columns[5].get_text().strip()),
        "win": int(columns[6].get_text().strip())
    }

    result.append(entry)

result = sorted(result, key=lambda item: item["username"])

print(json.dumps(result, indent=4, sort_keys=True))
